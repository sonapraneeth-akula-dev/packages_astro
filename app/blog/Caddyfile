# Caddy reverse proxy for the Grihasetu blog.
#
# Local development:
#   The dev/test/ppe hosts are served over HTTPS with Caddy's internal CA
#   (`tls internal`). Combined with a hosts-file entry pointing these names at
#   127.0.1.1 (run `bun run hosts:setup`), you can browse them locally.
#
# Production server:
#   For deployment on a public host with real DNS, remove `tls internal` from
#   the production block so Caddy automatically provisions and renews HTTPS
#   certificates via Let's Encrypt — no extra config needed.

{
	# Set an email to receive ACME/Let's Encrypt expiry notices in production.
	# email you@example.com
}

# ─── Development (hot reload) ────────────────────────────────────────────────
dev.blog.sonapraneeth.in {
	tls internal
	reverse_proxy dev:4322
}

# ─── Test (built output) ─────────────────────────────────────────────────────
test.blog.sonapraneeth.in {
	tls internal
	reverse_proxy test:4322
}

# ─── PPE / Pre-production (built output) ─────────────────────────────────────
ppe.blog.sonapraneeth.in {
	tls internal
	reverse_proxy ppe:4322
}

# ─── Production (built output, automatic HTTPS on a public server) ───────────
# Locally we use 'tls internal' as well. For deployment, remove 'tls internal'
# so Caddy can automatically provision real public certificates via
# Let's Encrypt / ZeroSSL.
blog.sonapraneeth.in {
	tls internal
	reverse_proxy prod:4322
}
