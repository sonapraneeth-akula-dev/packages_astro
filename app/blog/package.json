{
  "name": "@grihasetu/blog-app",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "description": "Grihasetu blog site built on @grihasetu/blog-core (categories, tags, offline search, synced code tabs).",
  "scripts": {
    "dev": "bun ../../node_modules/astro/bin/astro.mjs dev",
    "dev:host": "bun ../../node_modules/astro/bin/astro.mjs dev --host 0.0.0.0 --port 4322",
    "dev:serve": "bun run scripts/dev-server.ts",
    "start": "bun ../../node_modules/astro/bin/astro.mjs dev",
    "build": "bun ../../node_modules/astro/bin/astro.mjs build && bun ../../node_modules/pagefind/lib/runner/bin.cjs --site dist",
    "search:index": "bun ../../node_modules/astro/bin/astro.mjs build && bun ../../node_modules/pagefind/lib/runner/bin.cjs --site dist --output-path public/pagefind",
    "preview": "bun ../../node_modules/astro/bin/astro.mjs preview --host 0.0.0.0 --port 4322",
    "check": "bun ../../node_modules/astro/bin/astro.mjs check",
    "watch:content": "bun run scripts/watch-content.ts",
    "hosts:setup": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/setup-hosts.ps1",
    "hosts:remove": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/setup-hosts.ps1 -Remove",
    "certs:setup": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/setup-certs.ps1",
    "certs:remove": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/setup-certs.ps1 -Remove",
    "docker:dev": "bun run scripts/docker-compose.ts up dev caddy --build",
    "docker:test": "bun run scripts/docker-compose.ts up test caddy --build -d",
    "docker:ppe": "bun run scripts/docker-compose.ts up ppe caddy --build -d",
    "docker:prod": "bun run scripts/docker-compose.ts up prod caddy --build -d",
    "docker:up": "bun run scripts/docker-compose.ts up --build -d",
    "docker:down": "bun run scripts/docker-compose.ts down",
    "docker:logs": "bun run scripts/docker-compose.ts logs -f",
    "deploy": "bun run scripts/docker-compose.ts up prod caddy --build -d"
  },
  "dependencies": {
    "@grihasetu/blog-core": "workspace:*",
    "astro": "^6.4.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^25.9.3",
    "chokidar": "^4.0.3",
    "pagefind": "^1.3.0",
    "typescript": "^6.0.3"
  }
}