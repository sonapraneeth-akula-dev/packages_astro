---
/**
 * Go-notes-specific component: a "Run on the Go Playground" call-to-action that
 * links a code snippet to play.golang.org. Demonstrates how a notes site adds
 * its own components on top of the shared @sonapraneeth/notes-core set.
 */
import Icon from '@sonapraneeth/components/Icon.astro';

interface Props {
  /** Full URL to a saved playground snippet (e.g. https://go.dev/play/p/xxxx). */
  href?: string;
  /** Short label describing what the snippet does. */
  label?: string;
}

const { href = 'https://go.dev/play/', label = 'Try this on the Go Playground' } =
  Astro.props;
---

<a class="go-playground" href={href} target="_blank" rel="noopener noreferrer">
  <span class="gopher" aria-hidden="true">🐹</span>
  <span class="go-playground__text">{label}</span>
  <Icon name="external" size="1rem" />
</a>

<style>
  .go-playground {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-block: 1.25rem;
    padding: 0.6rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-subtle);
    color: var(--text);
    font-weight: 600;
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .go-playground:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.07);
  }
  .gopher {
    font-size: 1.2rem;
    line-height: 1;
  }
</style>
