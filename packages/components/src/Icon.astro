---
/**
 * Renders a named icon from the curated set in `icons.ts`. Sized in `em` so it
 * scales with surrounding text. Decorative by default (aria-hidden); pass a
 * `label` for a meaningful standalone icon.
 *
 *   <Icon name="external" />
 *   <Icon name="github" size="1.25rem" label="GitHub" />
 */
import { icons, type IconName } from './icons';

interface Props {
  name: IconName;
  size?: string;
  label?: string;
  class?: string;
}

const { name, size = '1em', label, class: className } = Astro.props;
const content = icons[name];
---

<svg
  class:list={['icon', className]}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  role={label ? 'img' : undefined}
  aria-label={label}
  aria-hidden={label ? undefined : 'true'}
  set:html={content}
/>

<style>
  .icon {
    flex: none;
    vertical-align: -0.125em;
  }
</style>
