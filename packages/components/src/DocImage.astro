---
/**
 * High-performance image for MDX. Imported (local) images are run through
 * Astro's image service (sharp) to emit modern formats, a responsive `srcset`
 * and intrinsic `width`/`height` (so there is zero layout shift). Lazy-loaded
 * and async-decoded by default; pass `priority` for above-the-fold hero images.
 *
 *   import hero from '../../assets/hero.png';
 *   <DocImage src={hero} alt="…" caption="…" />
 *   <DocImage src="https://…/remote.png" alt="…" width={1200} height={630} />
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata | string;
  alt: string;
  width?: number;
  height?: number;
  /** Candidate widths for the responsive srcset (local images only). */
  widths?: number[];
  /** The `sizes` attribute describing the rendered width across breakpoints. */
  sizes?: string;
  /** Optional caption rendered under the image. */
  caption?: string;
  /** Load eagerly + high priority (use for the single LCP image only). */
  priority?: boolean;
  class?: string;
}

const {
  src,
  alt,
  width,
  height,
  widths = [480, 800, 1200, 1600],
  sizes = '(max-width: 60rem) 100vw, 48rem',
  caption,
  priority = false,
  class: className,
} = Astro.props;

const isRemote = typeof src === 'string';
const loading = priority ? 'eager' : 'lazy';
const fetchpriority = priority ? 'high' : 'auto';
---

<figure class:list={['doc-image', className]}>
  {isRemote ? (
    <img
      src={src as string}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      decoding="async"
      fetchpriority={fetchpriority}
    />
  ) : (
    <Image
      src={src as ImageMetadata}
      alt={alt}
      widths={widths}
      sizes={sizes}
      loading={loading}
      decoding="async"
      fetchpriority={fetchpriority}
    />
  )}
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .doc-image {
    margin: 1.75rem 0;
  }
  .doc-image :global(img) {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--border);
    background: var(--surface);
  }
  .doc-image figcaption {
    margin-top: 0.6rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    text-align: center;
  }
</style>
