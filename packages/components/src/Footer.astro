---
import type { SiteChrome } from './chrome';
import { activeSocials } from './chrome';
import ScreenSizeIndicator from './ScreenSizeIndicator.astro';

interface Props {
  config: SiteChrome;
}
const { config } = Astro.props;

const socials = activeSocials(config);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="brand">{config.brand}<span class="accent-dot">.</span></a>
      <p>{config.description}</p>
    </div>

    <nav class="footer-nav" aria-label="Footer">
      {config.nav.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>

    {socials.length > 0 && (
      <ul class="footer-socials">
        {socials.map((s) => (
          <li>
            <a href={s.href} aria-label={s.label} rel="me noopener" target={s.href.startsWith('http') ? '_blank' : undefined}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <Fragment set:html={s.icon} />
              </svg>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
  <div class="container footer-base">
    <span>© {year} {config.author}. All rights reserved.</span>
    <span>Built with Astro · MDX</span>
  </div>
</footer>

{/* Dev-only live viewport / breakpoint badge (hidden in production). */}
<ScreenSizeIndicator />

<style>
  .site-footer {
    margin-top: 4rem;
    border-top: 1px solid var(--border);
    background: var(--surface);
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1fr auto;
    gap: 2rem;
    padding-block: 2.5rem 1.5rem;
    align-items: start;
  }
  .footer-brand .brand {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.2rem;
    color: var(--text);
  }
  .accent-dot { color: var(--accent); }
  .footer-brand p {
    color: var(--text-muted);
    font-size: 0.9rem;
    max-width: 28rem;
    margin: 0.6rem 0 0;
  }
  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 0.92rem;
  }
  .footer-nav a { color: var(--text-muted); font-weight: 600; }
  .footer-nav a:hover { color: var(--accent-text); }

  .footer-socials {
    display: flex;
    gap: 0.6rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .footer-socials a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    transition: all 0.15s ease;
  }
  .footer-socials a:hover { color: var(--accent-text); border-color: var(--accent); background: var(--accent-soft); }

  .footer-base {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-block: 1.25rem;
    border-top: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.82rem;
  }

  @media (max-width: 48rem) {
    .footer-inner { grid-template-columns: 1fr; gap: 1.5rem; }
  }
</style>
