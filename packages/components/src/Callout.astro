---
/**
 * Admonition / callout box for MDX prose (Starlight calls these "asides").
 *   <Callout type="warning" title="Heads up">…</Callout>
 *
 * `caution` is the Starlight-aligned alias of `warning` (same yellow triangle).
 */
type CalloutType = 'note' | 'tip' | 'important' | 'caution' | 'warning' | 'danger';

interface Props {
  type?: CalloutType;
  title?: string;
}

const { type = 'note', title } = Astro.props;

const icons: Record<CalloutType, string> = {
  note: '<circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line>',
  tip: '<path d="M9 18h6"></path><path d="M10 22h4"></path><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"></path>',
  important: '<path d="M12 2 2 7l10 5 10-5-10-5Z"></path><path d="m2 17 10 5 10-5"></path><path d="m2 12 10 5 10-5"></path>',
  caution: '<path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line>',
  warning: '<path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line>',
  danger: '<circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line>',
};

const labels: Record<CalloutType, string> = {
  note: 'Note',
  tip: 'Tip',
  important: 'Important',
  caution: 'Caution',
  warning: 'Warning',
  danger: 'Danger',
};
---

<aside class={`callout callout--${type}`} role="note">
  <p class="callout-head">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <Fragment set:html={icons[type]} />
    </svg>
    <span>{title ?? labels[type]}</span>
  </p>
  <div class="callout-body"><slot /></div>
</aside>

<style>
  .callout {
    --c: var(--accent);
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border);
    border-left: 3px solid var(--c);
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--c) 7%, var(--surface));
  }
  .callout--note { --c: #3b82f6; }
  .callout--tip { --c: #10b981; }
  .callout--important { --c: #8b5cf6; }
  .callout--caution { --c: #f59e0b; }
  .callout--warning { --c: #f59e0b; }
  .callout--danger { --c: #ef4444; }

  .callout-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 0.4rem;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.95rem;
    /* Blend the accent toward the page text so the label clears WCAG AA
       (4.5:1) on the tinted callout background — darkens in light mode and
       lightens in dark mode. The icon below keeps the vibrant accent. */
    color: color-mix(in srgb, var(--c) 50%, var(--text));
  }
  .callout-head svg {
    /* Icons are graphical (contrast-exempt), so keep them fully accented. */
    color: var(--c);
    flex: none;
  }
  .callout-body :global(p:last-child) { margin-bottom: 0; }
  .callout-body :global(p:first-child) { margin-top: 0; }
</style>
