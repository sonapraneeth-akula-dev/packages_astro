---
/**
 * A single notebook card for the hub home page (`index.astro`).
 *
 * The cover shows the notebook's optimised image when set, otherwise a stable
 * gradient carrying its accent emoji or title initials. Card-scoped styles live
 * here; the grid/section layout stays in `index.astro`.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { Notebook } from '../utils/docs';
import { truncateWords, coverInitials, coverHue } from '../utils/format';

interface Props {
  notebook: Notebook;
}

const { notebook: nb } = Astro.props;
---

<a class="notebook-card" href={nb.href} data-pagefind-ignore>
  <span class="notebook-cover" aria-hidden="true">
    {nb.coverImage ? (
      typeof nb.coverImage === 'string' ? (
        <img class="notebook-cover-img" src={nb.coverImage} alt="" loading="lazy" decoding="async" />
      ) : (
        <Image
          class="notebook-cover-img"
          src={nb.coverImage as ImageMetadata}
          alt=""
          widths={[320, 480, 640]}
          sizes="(max-width: 50rem) 100vw, 22rem"
          loading="lazy"
          decoding="async"
        />
      )
    ) : (
      <span class="notebook-cover-initials" style={`--cover-hue:${coverHue(nb.label)}`}>
        {nb.cover ? (
          <span class="notebook-cover-emoji">{nb.cover}</span>
        ) : (
          coverInitials(nb.label)
        )}
      </span>
    )}
  </span>
  <span class="notebook-body">
    <span class="notebook-title">
      {nb.label}
      {nb.badge && <span class="notebook-badge">{nb.badge}</span>}
      <span class="notebook-arrow" aria-hidden="true">→</span>
    </span>
    {nb.author && <span class="notebook-author">{nb.author}</span>}
    {nb.description && (
      <span class="notebook-desc">{truncateWords(nb.description, 100)}</span>
    )}
  </span>
</a>

<style>
  .notebook-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    color: var(--text);
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .notebook-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.07);
  }
  /* Cover sits on top, spanning the full card width with a fixed aspect ratio.
     Children are absolutely positioned so the (variable) image/emoji size never
     overrides the 16:9 box. */
  .notebook-cover {
    position: relative;
    display: block;
    aspect-ratio: 16 / 9;
    background: var(--bg-subtle);
    border-bottom: 1px solid var(--border);
  }
  .notebook-cover-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* Generated default cover: a stable gradient (hue derived from the title)
     carrying the notebook's initials, or its accent emoji when one is set. */
  .notebook-cover-initials {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 2.75rem;
    letter-spacing: 0.02em;
    color: #fff;
    background:
      linear-gradient(
        135deg,
        hsl(var(--cover-hue, 220) 65% 52%),
        hsl(calc(var(--cover-hue, 220) + 38) 68% 42%)
      );
  }
  .notebook-cover-emoji {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    line-height: 1;
    filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.25));
  }
  .notebook-body {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.1rem 1.25rem 1.25rem;
    min-width: 0;
  }
  .notebook-title {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.05rem;
  }
  .notebook-badge {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.1rem 0.4rem;
    border-radius: var(--radius-sm);
    background: var(--bg-subtle);
    color: var(--accent-text);
  }
  .notebook-author { color: var(--text-muted); font-size: 0.78rem; font-weight: 600; }
  .notebook-desc { color: var(--text-muted); font-size: 0.9rem; line-height: 1.5; }
  .notebook-arrow { margin-left: auto; color: var(--text-muted); font-size: 1.1rem; }
  .notebook-card:hover .notebook-arrow { color: var(--accent-text); }
</style>
