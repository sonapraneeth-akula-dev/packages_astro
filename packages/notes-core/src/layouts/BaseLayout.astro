---
import '../styles/global.css';
import { Font } from 'astro:assets';
import Header from '@sonapraneeth/components/Header.astro';
import Footer from '@sonapraneeth/components/Footer.astro';
import EnvBanner from '@sonapraneeth/components/EnvBanner.astro';
import ThemeSwitcher from '@sonapraneeth/components/ThemeSwitcher.astro';
import {
  resolveTheme,
  renderThemeStyle,
  renderThemeInitScript,
  themeFontVars,
} from '@sonapraneeth/components/theme';
import type { DocsConfig } from '../config';

interface Props {
  config: DocsConfig;
  title?: string;
  description?: string;
  /** Absolute or root-relative image for social cards. */
  ogImage?: string;
  /** Set to true on article/doc pages for og:type=article. */
  article?: boolean;
}

const {
  config,
  title,
  description = config.description,
  ogImage,
  article = false,
} = Astro.props;

const fullTitle =
  !title || title === config.title ? config.title : `${title} · ${config.title}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site) : undefined;
const appEnv = __APP_ENV__;

// Resolve the site's theme: accent palette + radius inline below, fonts loaded
// per the selected combo (only those families are registered in the config).
// With `theme.switcher`, every preset ships and the ThemeSwitcher panel renders.
const theme = resolveTheme(config.theme);
const themeStyle = renderThemeStyle(theme);
const fontVars = themeFontVars(theme);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={config.title} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="generator" content={Astro.generator} />

    {/* Per-config accent palette + corner radius. Only the selected palette's
        tokens ship; neutral surface tokens live in global.css. */}
    <style is:inline set:html={themeStyle}></style>

    {/* Self-hosted fonts for the selected combo. Body + heading preload (above
        the fold); mono is deferred since it only appears inside code blocks.
        The `system` combo registers nothing and uses the native OS stack. */}
    {fontVars.map((f) => <Font cssVariable={f.cssVariable} preload={f.preload} />)}

    {/* Theme-flash preventer: set data-theme before paint. */}
    <script is:inline>
      (() => {
        const stored = typeof localStorage !== 'undefined' && localStorage.getItem('theme');
        if (stored === 'light' || stored === 'dark') {
          document.documentElement.setAttribute('data-theme', stored);
        }
      })();
    </script>

    {/* Apply stored switcher selections (palette/font/radius) before paint. */}
    {theme.switcher && <script is:inline set:html={renderThemeInitScript()} />}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <EnvBanner env={appEnv} />
    <Header config={config} />
    <main id="main">
      <slot />
    </main>
    <Footer config={config} />
    {theme.switcher && <ThemeSwitcher theme={theme} />}
  </body>
</html>
