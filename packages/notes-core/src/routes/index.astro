---
/**
 * Injected home route (`/`).
 *
 * This page lives in the engine and is registered for every site by the route
 * integration in `defineDocsAstroConfig`. Per-site values (config, the MDX
 * component map and an optional curated sidebar) are supplied through the
 * `virtual:notes-core/*` modules the integration defines — so individual sites
 * carry no `src/pages/` of their own.
 */
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildHomeData } from '../utils/docs';
import { truncateWords, coverInitials, coverHue } from '../utils/format';
import { docsConfig } from 'virtual:notes-core/config';
import { components } from 'virtual:notes-core/components';
import { sidebar } from 'virtual:notes-core/sidebar';

const homeOptions = sidebar
  ? { sidebarConfig: sidebar }
  : { notebooks: docsConfig.notebooks };
const entries = await getCollection('docs');
const { rootEntry, next, notebooks } = buildHomeData(entries, homeOptions);

const hub = docsConfig.notebooks && !sidebar && notebooks.length > 0;
if (!rootEntry && !hub) {
  throw new Error('Missing root landing note: add src/content/docs/index.mdx');
}
const Rendered = rootEntry ? (await render(rootEntry)).Content : null;
---

<BaseLayout
  config={docsConfig}
  title={docsConfig.title}
  description={docsConfig.description}
>
  <article class="home container" data-pagefind-body>
    {Rendered && (
      <div class="home-prose">
        <Rendered components={components} />
      </div>
    )}

    {hub ? (
      <nav class="notebook-grid" aria-label="Notebooks">
        {notebooks.map((nb) => (
          <a class="notebook-card" href={nb.href} data-pagefind-ignore>
            <span class="notebook-cover" aria-hidden="true">
              {nb.coverImage ? (
                typeof nb.coverImage === 'string' ? (
                  <img class="notebook-cover-img" src={nb.coverImage} alt="" loading="lazy" decoding="async" />
                ) : (
                  <Image
                    class="notebook-cover-img"
                    src={nb.coverImage as ImageMetadata}
                    alt=""
                    widths={[320, 480, 640]}
                    sizes="(max-width: 50rem) 100vw, 22rem"
                    loading="lazy"
                    decoding="async"
                  />
                )
              ) : (
                <span class="notebook-cover-initials" style={`--cover-hue:${coverHue(nb.label)}`}>
                  {nb.cover ? (
                    <span class="notebook-cover-emoji">{nb.cover}</span>
                  ) : (
                    coverInitials(nb.label)
                  )}
                </span>
              )}
            </span>
            <span class="notebook-body">
              <span class="notebook-title">
                {nb.label}
                {nb.badge && <span class="notebook-badge">{nb.badge}</span>}
                <span class="notebook-arrow" aria-hidden="true">→</span>
              </span>
              {nb.author && <span class="notebook-author">{nb.author}</span>}
              {nb.description && (
                <span class="notebook-desc">{truncateWords(nb.description, 100)}</span>
              )}
            </span>
          </a>
        ))}
      </nav>
    ) : (
      next && (
        <a class="btn btn-primary home-cta" href={next.href} data-pagefind-ignore>
          Start reading: {next.label} →
        </a>
      )
    )}
  </article>
</BaseLayout>

<style>
  /* Fill the full --container like article pages do (it grows with the
     viewport), so wide screens aren't wasted. The prose, notebook grid and CTA
     all span the full width. */
  .home { padding-block: 3rem 4rem; }
  .home-prose :global(h1) { margin-bottom: 0.75rem; }
  .home-prose :global(h2) { margin-top: 2.5rem; }
  /* The hub/landing page has no table of contents, so the heading deep-link
     anchors serve no purpose here. */
  .home-prose :global(.heading-anchor) { display: none; }
  .home-prose :global(p),
  .home-prose :global(ul),
  .home-prose :global(ol) { margin-block: 1rem; }
  .home-prose :global(ul),
  .home-prose :global(ol) { padding-left: 1.4rem; }
  .home-cta { margin-top: 2rem; }

  .notebook-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 18rem), 1fr));
    gap: 1.25rem;
    margin-top: 2.5rem;
  }
  .notebook-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    color: var(--text);
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .notebook-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.07);
  }
  /* Cover sits on top, spanning the full card width with a fixed aspect ratio.
     Children are absolutely positioned so the (variable) image/emoji size never
     overrides the 16:9 box. */
  .notebook-cover {
    position: relative;
    display: block;
    aspect-ratio: 16 / 9;
    background: var(--bg-subtle);
    border-bottom: 1px solid var(--border);
  }
  .notebook-cover-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* Generated default cover: a stable gradient (hue derived from the title)
     carrying the notebook's initials, or its accent emoji when one is set. */
  .notebook-cover-initials {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 2.75rem;
    letter-spacing: 0.02em;
    color: #fff;
    background:
      linear-gradient(
        135deg,
        hsl(var(--cover-hue, 220) 65% 52%),
        hsl(calc(var(--cover-hue, 220) + 38) 68% 42%)
      );
  }
  .notebook-cover-emoji {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    line-height: 1;
    filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.25));
  }
  .notebook-body {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.1rem 1.25rem 1.25rem;
    min-width: 0;
  }
  .notebook-title {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.05rem;
  }
  .notebook-badge {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.1rem 0.4rem;
    border-radius: var(--radius-sm);
    background: var(--bg-subtle);
    color: var(--accent-text);
  }
  .notebook-author { color: var(--text-muted); font-size: 0.78rem; font-weight: 600; }
  .notebook-desc { color: var(--text-muted); font-size: 0.9rem; line-height: 1.5; }
  .notebook-arrow { margin-left: auto; color: var(--text-muted); font-size: 1.1rem; }
  .notebook-card:hover .notebook-arrow { color: var(--accent-text); }
</style>
