---
/**
 * Injected doc route (`/[...slug]`) — renders every note except the root
 * landing page. Registered for every site by the route integration in
 * `defineDocsAstroConfig`; per-site config, components and the optional curated
 * sidebar arrive via the `virtual:notes-core/*` modules.
 */
import { getCollection, render } from 'astro:content';
import DocLayout from '../layouts/DocLayout.astro';
import { buildDocRoutes, editUrl } from '../utils/docs';
import { readingTime } from '../utils/format';
import { docsConfig } from 'virtual:notes-core/config';
import { components } from 'virtual:notes-core/components';
import { sidebar } from 'virtual:notes-core/sidebar';

export async function getStaticPaths() {
  const entries = await getCollection('docs');
  // A curated sidebar.json (when present) overrides the auto-generated tree, so
  // the sidebar, prev/next and breadcrumbs all follow the curated order. When
  // notebooks mode is on, each top-level folder gets its own scoped sidebar.
  return buildDocRoutes(
    entries,
    sidebar ? { sidebarConfig: sidebar } : { notebooks: docsConfig.notebooks },
  );
}

const { entry, tree, prev, next, breadcrumbs, notebook, backLink } = Astro.props;
const { Content, headings } = await render(entry);

// Ship KaTeX CSS only when the note has math: `math: true` in frontmatter, or an
// unescaped `$` in the body (remark-math's delimiter).
const needsKatex = entry.data.math || /(?<!\\)\$/.test(entry.body ?? '');
---

<DocLayout
  config={docsConfig}
  title={entry.data.title}
  description={entry.data.description}
  headings={headings}
  tree={tree}
  breadcrumbs={breadcrumbs}
  prev={prev ?? undefined}
  next={next ?? undefined}
  readingTime={readingTime(entry.body)}
  lastUpdated={entry.data.lastUpdated}
  editUrl={editUrl(entry, docsConfig.editUrlBase)}
  cover={entry.data.cover}
  tableOfContents={entry.data.tableOfContents}
  needsKatex={needsKatex}
  notebookLabel={notebook?.label}
  backLink={backLink ?? undefined}
>
  <Content components={components} />
</DocLayout>
