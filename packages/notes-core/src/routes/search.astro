---
/**
 * Injected search route (`/search`). Only registered when `docsConfig.search`
 * is enabled. The Pagefind index is generated at build time into `/pagefind/`
 * and is absent on the dev server, so the widget degrades gracefully with a
 * build hint.
 *
 * The widget reads its filters from the live Pagefind index, so the notebook
 * facet (notebooks mode) is shown up front. A `/search?notebook=Go` deep link
 * pre-selects that scope so a sub-note can offer a search box scoped to itself.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PagefindSearch from '@sonapraneeth/components/PagefindSearch.astro';
import { docsConfig } from 'virtual:notes-core/config';

// Notebooks have no taxonomy index page, so the notebook chip stays a
// filter-only toggle (no link) with an icon + separated count.
const searchFilters = {
  notebook: { label: 'Notebook', icon: 'notebook' as const },
};

// (#2) Metadata shown in each result card's meta line. No date sort here —
// notes aren't all dated, and an applied sort drops untagged pages.
const searchMeta = [
  { key: 'notebook', icon: 'notebook' as const },
  { key: 'date', icon: 'calendar' as const },
  { key: 'reading', icon: 'clock' as const },
];
---

<BaseLayout
  config={docsConfig}
  title="Search"
  description={`Search ${docsConfig.title}. Runs entirely in your browser — no server round-trips.`}
>
  <div class="container page-head">
    <p class="eyebrow">Find anything</p>
    <h1>Search</h1>
    <p class="lede">
      A fully client-side index — works offline once the page has loaded, with no
      server calls.
    </p>
  </div>

  <div class="container">
    <PagefindSearch
      placeholder={`Search ${docsConfig.title}…`}
      filters={searchFilters}
      meta={searchMeta}
      highlight
    />
  </div>
</BaseLayout>

