---
/**
 * Injected search route (`/search`). Only registered when `docsConfig.search`
 * is enabled. The Pagefind UI bundle is generated at build time into
 * `/pagefind/` and is absent on the dev server, so the page degrades gracefully
 * with a hint.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { docsConfig } from 'virtual:notes-core/config';
---

<BaseLayout
  config={docsConfig}
  title="Search"
  description={`Search ${docsConfig.title}. Runs entirely in your browser — no server round-trips.`}
>
  <div class="container page-head">
    <p class="eyebrow">Find anything</p>
    <h1>Search</h1>
    <p class="lede">
      A fully client-side index — works offline once the page has loaded, with no
      server calls.
    </p>
  </div>

  <div class="container search-wrap">
    <p id="search-scope" class="search-scope" hidden>
      Searching within <strong id="search-scope-name"></strong>.
      <a href="/search">Search everything →</a>
    </p>
    <div id="search" data-pagefind-ui></div>
    <p id="search-fallback" class="search-fallback" hidden>
      The search index is generated at build time. To try it on the dev server,
      run <code>bun run search:index</code> once to emit the index into
      <code>public/pagefind/</code>, then reload this page. A full
      <code>bun run build</code> also produces it for the preview.
    </p>
  </div>
</BaseLayout>

<script>
  // Pagefind assets are emitted into /pagefind/ during the build step
  // (`pagefind --site dist`) and are absent on the dev server. The UI bundle is
  // a classic script exposing a global `PagefindUI`, so we inject it as a
  // <script> tag and degrade gracefully with a hint if it is missing.
  function initSearch() {
    const fallback = document.getElementById('search-fallback');
    const showFallback = () => {
      if (fallback) fallback.hidden = false;
    };

    // Optional per-notebook scope: `/search?notebook=Go` pre-applies the
    // notebook filter so a sub-note can offer a search box scoped to itself.
    const params = new URLSearchParams(window.location.search);
    const scope = params.get('notebook');

    const css = document.createElement('link');
    css.rel = 'stylesheet';
    css.href = '/pagefind/pagefind-ui.css';
    document.head.appendChild(css);

    const script = document.createElement('script');
    script.src = '/pagefind/pagefind-ui.js';
    script.onload = () => {
      const PagefindUI = (window as unknown as {
        PagefindUI?: new (opts: unknown) => void;
      }).PagefindUI;
      if (!PagefindUI) {
        showFallback();
        return;
      }
      new PagefindUI({
        element: '#search',
        showSubResults: true,
        showImages: false,
        pageSize: 8,
        resetStyles: false,
        openFilters: ['notebook', 'Notebook'],
      });
      if (scope) applyScope(scope);
    };
    script.onerror = showFallback;
    document.body.appendChild(script);
  }

  // Tick the notebook filter checkbox whose label matches `value` once Pagefind
  // has rendered the filter panel, then announce the active scope.
  function applyScope(value: string) {
    const root = document.getElementById('search');
    if (!root) return;
    const banner = document.getElementById('search-scope');
    const name = document.getElementById('search-scope-name');
    if (banner && name) {
      name.textContent = value;
      banner.hidden = false;
    }

    let done = false;
    const tryCheck = () => {
      if (done) return true;
      const inputs = root.querySelectorAll<HTMLInputElement>('input[type="checkbox"]');
      for (const input of inputs) {
        const text = (input.closest('label')?.textContent ?? '').trim();
        if (text === value || text.startsWith(value)) {
          if (!input.checked) input.click();
          done = true;
          return true;
        }
      }
      return false;
    };

    if (tryCheck()) return;
    const observer = new MutationObserver(() => {
      if (tryCheck()) observer.disconnect();
    });
    observer.observe(root, { childList: true, subtree: true });
    // Stop observing after a few seconds in case the filter never appears.
    setTimeout(() => observer.disconnect(), 5000);
  }

  initSearch();
</script>

<style is:global>
  #search {
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-text: var(--text);
    --pagefind-ui-background: var(--surface);
    --pagefind-ui-border: var(--border);
    --pagefind-ui-tag: var(--bg-subtle);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: var(--radius);
    --pagefind-ui-font: var(--font-sans);
  }
  #search .pagefind-ui__search-input {
    color: var(--text);
    background: var(--bg-subtle);
    border-color: var(--border);
  }
  #search .pagefind-ui__search-input::placeholder {
    color: var(--text-muted);
    opacity: 1;
  }
  #search .pagefind-ui__search-clear {
    top: calc(3px * var(--pagefind-ui-scale));
    inset-inline-end: calc(8px * var(--pagefind-ui-scale));
    height: calc(58px * var(--pagefind-ui-scale));
    width: calc(58px * var(--pagefind-ui-scale));
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    color: var(--text-muted);
    font-size: 0;
    cursor: pointer;
    transition: color 0.15s ease;
  }
  #search .pagefind-ui__search-clear::before {
    content: "\00d7";
    font-size: 1.6rem;
    line-height: 1;
    transform: translateY(-0.04em);
  }
  #search .pagefind-ui__search-clear:hover { color: var(--text); }
  #search .pagefind-ui__result {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    padding: 1.1rem 1.3rem;
    margin-bottom: 0.85rem;
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  #search .pagefind-ui__result:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.07);
  }
</style>

<style>
  .search-wrap { padding-bottom: 3rem; max-width: 48rem; }
  .search-scope {
    margin: 0 0 1rem;
    padding: 0.7rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-subtle);
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  .search-scope a { font-weight: 600; }
  .search-fallback {
    margin-top: 1rem;
    padding: 1rem 1.25rem;
    border: 1px dashed var(--border);
    border-radius: var(--radius);
    color: var(--text-muted);
    background: var(--surface);
  }
</style>
