---
/**
 * The left documentation sidebar: a sticky, scrollable navigation rail on
 * desktop and a collapsible drawer on mobile. The tree is generated by
 * `buildSidebar` (auto from folders/frontmatter, or a `sidebar.json` override).
 */
import type { SidebarNode } from '../utils/docs';
import SidebarTree from './SidebarTree.astro';

interface Props {
  tree: SidebarNode[];
  currentPath: string;
  /** Heading shown above the tree (defaults to the site subject). */
  label?: string;
}

const { tree, currentPath, label = 'Contents' } = Astro.props;
---

<nav class="docs-sidebar" aria-label="Documentation navigation" data-pagefind-ignore>
  <button class="docs-sidebar-toggle" type="button" aria-expanded="false" aria-controls="docs-sidebar-panel">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="3" y1="12" x2="21" y2="12"></line>
      <line x1="3" y1="6" x2="21" y2="6"></line>
      <line x1="3" y1="18" x2="21" y2="18"></line>
    </svg>
    <span>{label}</span>
  </button>
  <div class="docs-sidebar-panel" id="docs-sidebar-panel">
    <p class="docs-sidebar-label">{label}</p>
    <div class="docs-sidebar-scroll">
      <SidebarTree items={tree} currentPath={currentPath} />
    </div>
  </div>
</nav>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.docs-sidebar-toggle');
  const panel = document.getElementById('docs-sidebar-panel');
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    panel?.classList.toggle('is-open', !open);
  });
  // Close the mobile drawer after navigating.
  panel?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('a') && window.innerWidth <= 960) {
      toggle?.setAttribute('aria-expanded', 'false');
      panel.classList.remove('is-open');
    }
  });
</script>

<style>
  .docs-sidebar {
    font-size: 0.9rem;
  }
  .docs-sidebar-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0 0 0.75rem;
    padding-left: 0.5rem;
  }
  .docs-sidebar-scroll {
    overflow-y: auto;
  }

  /* Desktop: sticky rail. The layout grid gives it the left column. */
  @media (min-width: 60.0625rem) {
    .docs-sidebar-toggle { display: none; }
    .docs-sidebar-panel {
      position: sticky;
      top: 5.5rem;
      max-height: calc(100dvh - 7rem);
      display: flex;
      flex-direction: column;
    }
    .docs-sidebar-scroll {
      flex: 1;
      padding-right: 0.5rem;
    }
  }

  /* Mobile: a toggle button reveals the panel inline. */
  @media (max-width: 60rem) {
    .docs-sidebar-toggle {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      width: 100%;
      padding: 0.65rem 0.9rem;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--surface);
      color: var(--text);
      font-family: var(--font-heading);
      font-weight: 600;
      font-size: 0.95rem;
      cursor: pointer;
    }
    .docs-sidebar-label { display: none; }
    .docs-sidebar-panel {
      display: none;
      margin-top: 0.75rem;
      padding: 1rem;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--surface);
    }
    .docs-sidebar-panel.is-open { display: block; }
  }
</style>
