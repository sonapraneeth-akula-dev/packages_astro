---
import { getCollection, render } from 'astro:content';
import DocLayout from '@grihasetu/notes-core/layouts/DocLayout.astro';
import { buildDocRoutes, editUrl, readingTime } from '@grihasetu/notes-core';
import type { SidebarConfig } from '@grihasetu/notes-core';
import { components } from '../components/registry';
import { docsConfig } from '../../docs.config';
import sidebar from '../../sidebar.json';

export async function getStaticPaths() {
  const entries = await getCollection('docs');
  // This site overrides the auto-generated sidebar with a curated sidebar.json
  // (validated by sidebarSchema). Pass it through so the tree, prev/next and
  // breadcrumbs all follow the curated order.
  return buildDocRoutes(entries, { sidebarConfig: sidebar as SidebarConfig });
}

const { entry, tree, prev, next, breadcrumbs } = Astro.props;
const { Content, headings } = await render(entry);
---

<DocLayout
  config={docsConfig}
  title={entry.data.title}
  description={entry.data.description}
  headings={headings}
  tree={tree}
  breadcrumbs={breadcrumbs}
  prev={prev ?? undefined}
  next={next ?? undefined}
  readingTime={readingTime(entry.body)}
  lastUpdated={entry.data.lastUpdated}
  editUrl={editUrl(entry, docsConfig.editUrlBase)}
  cover={entry.data.cover}
  tableOfContents={entry.data.tableOfContents}
>
  <Content components={components} />
</DocLayout>
