{
  "name": "@sonapraneeth/blog-core",
  "version": "1.5.0",
  "type": "module",
  "description": "Shared blog engine for Astro + MDX: components, layouts, injected routes, posts collection, config schema and an Astro config factory.",
  "exports": {
    ".": "./src/index.ts",
    "./content": "./src/content.ts",
    "./config": "./src/config.ts",
    "./schema": "./src/schema.ts",
    "./astro": "./src/astro-config.ts",
    "./styles/global.css": "./src/styles/global.css",
    "./components/mdx": "./src/components/mdx.ts",
    "./components/*": "./src/components/*",
    "./layouts/*": "./src/layouts/*",
    "./routes/*": "./src/routes/*",
    "./utils/*": "./src/utils/*"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.12",
    "@astrojs/sitemap": "catalog:",
    "@expressive-code/plugin-line-numbers": "catalog:",
    "@sonapraneeth/components": "workspace:*",
    "@sonapraneeth/rehype-satteri-autolink-headings": "workspace:*",
    "astro": "catalog:",
    "astro-expressive-code": "catalog:",
    "katex": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}