---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostRow from '../../components/PostRow.astro';
import CategoryIcon from '../../components/CategoryIcon.astro';
import {
  getPublishedPosts,
  getCategories,
  postsInCategory,
  readingTime,
  type Post,
} from '../../utils/posts';

export const getStaticPaths = (async () => {
  const posts = await getPublishedPosts();
  return getCategories(posts).map((cat) => ({
    params: { category: cat.slug },
    props: { name: cat.name, posts: postsInCategory(posts, cat.slug) },
  }));
}) satisfies GetStaticPaths;

const { name, posts } = Astro.props as { name: string; posts: Post[] };
---

<BaseLayout title={`${name} · Category`} description={`Posts in the ${name} category.`}>
  <div class="container page-head">
    <p class="eyebrow"><a href="/categories">Categories</a> /</p>
    <h1 class="page-title"><CategoryIcon />{name}</h1>
    <p class="lede">{posts.length} {posts.length === 1 ? 'post' : 'posts'} in this category.</p>
  </div>

  <div class="container rows">
    {posts.map((post) => (
      <PostRow post={post} readingTime={readingTime(post.body)} />
    ))}
  </div>
</BaseLayout>

<style>
  .rows {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding-bottom: 2rem;
  }
  .page-head .eyebrow a { color: var(--accent-text); }
  .page-title {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .page-title :global(.icon-category) { color: var(--accent-text); }
</style>
