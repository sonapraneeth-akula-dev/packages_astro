---
/**
 * Injected search route (`/search`). The Pagefind index is generated at build
 * time into `/pagefind/` and is absent on the dev server, so the widget
 * degrades gracefully with a build hint.
 *
 * The widget reads its filters from the live Pagefind index, so the category
 * and tag facets are shown up front. `/search?category=…` and `/search?tag=…`
 * deep links pre-select that scope so a category/tag page can offer a search
 * box scoped to itself.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PagefindSearch from '@sonapraneeth/components/PagefindSearch.astro';
import { blogConfig } from 'virtual:blog-core/config';

// Chip presentation: the category/tag label links to its taxonomy page, while
// the count segment toggles the in-page filter.
const searchFilters = {
  category: { label: 'Category', hrefBase: '/categories/', icon: 'category' as const },
  tag: { label: 'Tag', hrefBase: '/tags/', icon: 'tag' as const },
};

// (#1) Date sort — posts are tagged `data-pagefind-sort="date:..."`.
const searchSorts = [
  { id: 'date-desc', label: 'Newest', key: 'date', dir: 'desc' as const },
  { id: 'date-asc', label: 'Oldest', key: 'date', dir: 'asc' as const },
];

// (#2) Metadata shown in each result card's meta line.
const searchMeta = [
  { key: 'cover' },
  { key: 'category', icon: 'category' as const },
  { key: 'date', icon: 'calendar' as const },
  { key: 'reading', icon: 'clock' as const },
];
---

<BaseLayout
  title="Search"
  description={`Search ${blogConfig.title}. Runs entirely in your browser — no server round-trips.`}
>
  <div class="container page-head">
    <p class="eyebrow">Find anything</p>
    <h1>Search</h1>
    <p class="lede">
      A fully client-side index — works offline once the page has loaded, with no
      server calls.
    </p>
  </div>

  <div class="container">
    <PagefindSearch
      placeholder={`Search ${blogConfig.title}…`}
      filters={searchFilters}
      sorts={searchSorts}
      meta={searchMeta}
      highlight
    />
  </div>
</BaseLayout>

