---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostRow from '../../components/PostRow.astro';
import TagIcon from '../../components/TagIcon.astro';
import {
  getPublishedPosts,
  getTags,
  postsWithTag,
  readingTime,
  type Post,
} from '../../utils/posts';

export const getStaticPaths = (async () => {
  const posts = await getPublishedPosts();
  return getTags(posts).map((tag) => ({
    params: { tag: tag.slug },
    props: { name: tag.name, posts: postsWithTag(posts, tag.slug) },
  }));
}) satisfies GetStaticPaths;

const { name, posts } = Astro.props as { name: string; posts: Post[] };
---

<BaseLayout title={`#${name} · Tag`} description={`Posts tagged ${name}.`}>
  <div class="container page-head">
    <p class="eyebrow"><a href="/tags">Tags</a> /</p>
    <h1 class="page-title"><TagIcon />{name}</h1>
    <p class="lede">{posts.length} {posts.length === 1 ? 'post' : 'posts'} tagged with this.</p>
  </div>

  <div class="container rows">
    {posts.map((post) => (
      <PostRow post={post} readingTime={readingTime(post.body)} />
    ))}
  </div>
</BaseLayout>

<style>
  .rows {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding-bottom: 2rem;
  }
  .page-head .eyebrow a { color: var(--accent-text); }
  .page-title {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .page-title :global(.icon-tag) { color: var(--accent-text); }
</style>
