---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="The page you were looking for does not exist.">
  <div class="container notfound">
    <p class="code">404</p>
    <h1>This page wandered off.</h1>
    <p class="lede">
      The page you were looking for doesn't exist or has moved. Try the home feed
      or search for what you need.
    </p>
    <div class="actions">
      <a class="btn btn-primary" href="/">Back home</a>
      <a class="btn" href="/search">Search</a>
    </div>
  </div>
</BaseLayout>

<style>
  .notfound {
    text-align: center;
    padding-block: 5rem 4rem;
    max-width: 36rem;
    margin-inline: auto;
  }
  .code {
    font-family: var(--font-mono);
    font-size: 4rem;
    font-weight: 700;
    color: var(--accent-text);
    margin: 0;
    line-height: 1;
  }
  .notfound h1 { margin: 0.5rem 0 0.75rem; }
  .lede { color: var(--text-muted); font-size: 1.1rem; }
  .actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }
</style>
