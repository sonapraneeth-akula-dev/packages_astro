---
import BaseLayout from '@grihasetu/notes-core/layouts/BaseLayout.astro';
import { docsConfig } from '../../docs.config';
---

<BaseLayout config={docsConfig} title="Page not found" description="That page does not exist.">
  <div class="container page-head not-found">
    <p class="eyebrow">404</p>
    <h1>Page not found</h1>
    <p class="lede">The page you were looking for doesn’t exist or has moved.</p>
    <a class="btn btn-primary" href="/">← Back home</a>
  </div>
</BaseLayout>

<style>
  .not-found { padding-block: 5rem; }
  .not-found .btn { margin-top: 1.5rem; }
</style>
